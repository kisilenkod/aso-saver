rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users — can only read/write own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Apps — access based on membership
    match /apps/{appId} {
      // Anyone authenticated can create (they become owner)
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;

      // Read — only members
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberIds;

      // Update — owner or editor
      allow update: if request.auth != null
        && request.auth.uid in resource.data.memberIds
        && (resource.data.members[request.auth.uid].role == 'owner'
            || resource.data.members[request.auth.uid].role == 'editor');

      // Delete — owner only
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }
  }
}
